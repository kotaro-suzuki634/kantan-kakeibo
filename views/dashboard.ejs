<%- include('partials/header') %>
<div class="page-head"><div><p class="eyebrow"><%= month.replace('-','年') %>月</p><h1>今月のお金</h1></div><a class="button primary" href="/input">＋ 支出を入力</a></div>
<section class="hero-card"><div><p>自由に使える残額</p><strong>¥<%= Math.max(0,available-totals.spent).toLocaleString('ja-JP') %></strong><p class="muted">収入・月収 − 貯金目標 − 支払い済み支出</p></div><div class="gauge" style="--rate:<%= Math.min(rate,100) %>"><span><%= rate %>%</span><small><%= status.label %></small></div></section>
<div class="advice <%= status.key %>"><span>💡</span><p><%= advice %></p></div>
<section class="stat-grid"><article class="stat"><span>今月の収入</span><strong>¥<%= totals.income.toLocaleString('ja-JP') %></strong><small>設定月収 ¥<%= user.monthly_income.toLocaleString('ja-JP') %></small></article><article class="stat"><span>今月の支出</span><strong>¥<%= totals.spent.toLocaleString('ja-JP') %></strong><small>月末予測 ¥<%= projection.toLocaleString('ja-JP') %></small></article><article class="stat"><span>固定費（予定含む）</span><strong>¥<%= totals.fixed.toLocaleString('ja-JP') %></strong><small><a href="/fixed-costs">固定費を管理 →</a></small></article><article class="stat"><span>削減できそう</span><strong>¥<%= food.reducible.toLocaleString('ja-JP') %></strong><small>食費 ¥<%= food.total.toLocaleString('ja-JP') %> のうち</small></article></section>
<section class="card"><div class="section-title"><h2>カテゴリー別の目安</h2><a href="/settings">割合を変更</a></div><div class="budget-list"><% budgetRows.forEach(b=>{ %><div class="budget-row"><div><span class="category-dot" style="background:<%= b.color %>"></span><b><%= b.category %></b><small>¥<%= b.used.toLocaleString('ja-JP') %> / ¥<%= b.limit.toLocaleString('ja-JP') %></small></div><div class="progress"><i style="width:<%= Math.min(b.rate,100) %>%"></i></div><strong><%= b.rate %>%</strong></div><% }) %></div></section>
<section class="card"><div class="section-title"><h2>最近の記録</h2><a href="/transactions">すべて見る</a></div><div class="transaction-list"><% if(!recent.length){ %><div class="empty">まだ記録がありません。話すように入力してみましょう。</div><% } recent.forEach(t=>{ %><a href="/transactions/<%= t.id %>" class="transaction-item"><span class="cat-icon" style="background:<%= t.category_color %>"><%= t.category_icon %></span><div><b><%= t.title %></b><small><%= new Date(t.transaction_date).toLocaleDateString('ja-JP') %> · <%= t.category %><%= t.payment_status==='scheduled'?' · 予定':'' %></small></div><strong class="<%= t.type %>"><%= t.type==='income'?'+':'−' %>¥<%= t.amount.toLocaleString('ja-JP') %></strong></a><% }) %></div></section>
<%- include('partials/footer') %>
