<%- include('partials/header') %><div class="page-head"><div><p class="eyebrow">記録を振り返る</p><h1>支出履歴</h1></div><a class="button primary" href="/input">＋ 入力</a></div><form class="month-form"><input type="month" name="month" value="<%= month %>"><button class="button ghost">表示</button></form><section class="card transaction-list"><% if(!transactions.length){ %><div class="empty">この月の記録はありません。</div><% } transactions.forEach(t=>{ %><a href="/transactions/<%= t.id %>" class="transaction-item"><span class="cat-icon" style="background:<%= t.category_color %>"><%= t.category_icon %></span><div><b><%= t.title %></b><small><%= new Date(t.transaction_date).toLocaleDateString('ja-JP') %> · <%= t.category %><%= t.food_necessity&&t.food_necessity!=='未判定'?' · '+t.food_necessity:'' %></small></div><strong class="<%= t.type %>"><%= t.type==='income'?'+':'−' %>¥<%= t.amount.toLocaleString('ja-JP') %></strong></a><% }) %></section><%- include('partials/footer') %>
