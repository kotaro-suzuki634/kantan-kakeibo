<%- include('partials/header') %>
<div class="narrow"><div class="page-head"><div><p class="eyebrow">LINEみたいに、ひとこと</p><h1>かんたん入力</h1></div></div>
<section class="chat-card"><div class="chat-intro"><span class="bot-avatar">¥</span><div class="bubble bot">今日使ったお金を教えてください。<br><small>例：セブンでお昼 680円</small></div></div>
<% if(parsed){ %><div class="chat-user"><div class="bubble user"><%= text %></div></div><div class="chat-intro"><span class="bot-avatar">¥</span><div class="bubble bot result"><b>こう解析しました</b><dl><div><dt>内容</dt><dd><%= parsed.title %></dd></div><div><dt>金額</dt><dd>¥<%= parsed.amount.toLocaleString('ja-JP') %></dd></div><div><dt>カテゴリー</dt><dd><%= parsed.category %></dd></div><% if(parsed.category==='食費'){ %><div><dt>食費の判定</dt><dd><%= parsed.foodNecessity %></dd></div><% } %><div><dt>日付</dt><dd><%= parsed.transactionDate %></dd></div><div><dt>信頼度</dt><dd><%= ({high:'高',medium:'中',low:'低'})[parsed.confidence] %></dd></div></dl></div></div>
<form class="confirm-card" method="post" action="/transactions"><input type="hidden" name="amount" value="<%= parsed.amount %>"><input type="hidden" name="title" value="<%= parsed.title %>"><input type="hidden" name="merchant" value="<%= parsed.merchant||'' %>"><input type="hidden" name="category" value="<%= parsed.category %>"><input type="hidden" name="food_necessity" value="<%= parsed.foodNecessity %>"><input type="hidden" name="transaction_date" value="<%= parsed.transactionDate %>"><input type="hidden" name="type" value="<%= parsed.type %>"><input type="hidden" name="original_text" value="<%= parsed.originalText %>"><input type="hidden" name="classification_confidence" value="<%= parsed.confidence %>"><input type="hidden" name="memo" value="<%= parsed.memo %>"><button class="button primary wide" type="submit">この内容で登録</button><a class="button ghost wide" href="/input">入力し直す</a></form><% } %>
<form class="chat-form" method="post" action="/transactions/parse"><label class="sr-only" for="text">支出を自然文で入力</label><input id="text" name="text" required maxlength="500" autocomplete="off" placeholder="例：スタバ 550円" value="<%= parsed?'':text %>"><button type="submit" aria-label="解析する">➤</button></form>
</section><div class="examples"><span>試してみる</span><button data-example="昨日コンビニでお菓子300円">昨日コンビニでお菓子300円</button><button data-example="日吉から渋谷 電車 230円">日吉から渋谷 電車 230円</button><button data-example="給料 120000円">給料 120000円</button></div></div>
<%- include('partials/footer') %>
