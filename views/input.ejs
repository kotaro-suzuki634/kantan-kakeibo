<%- include('partials/header') %>
<div class="narrow"><div class="page-head"><div><p class="eyebrow">LINEみたいに、ひとこと</p><h1>かんたん入力</h1></div></div>
<% if(errors?.length){ %><div class="form-errors" role="alert"><b>入力内容を確認してください</b><ul><% errors.forEach(e=>{ %><li><%= e %></li><% }) %></ul></div><% } %>
<section class="chat-card"><div class="chat-intro"><span class="bot-avatar">¥</span><div class="bubble bot">今日使ったお金を教えてください。<br><small>例：セブンでお昼 680円</small></div></div>
<% if(parsed){ const selectedId=Number(parsed.categoryId||parsed.category_id); %><div class="chat-user"><div class="bubble user"><%= text %></div></div><div class="chat-intro"><span class="bot-avatar">¥</span><div class="bubble bot result"><b>こう解析しました</b><dl><div><dt>内容</dt><dd><%= parsed.title %></dd></div><div><dt>金額</dt><dd>¥<%= Number(parsed.amount).toLocaleString('ja-JP') %></dd></div><div><dt>カテゴリー</dt><dd><%= parsed.category %></dd></div><% if(parsed.category==='食費'){ %><div><dt>食費の判定</dt><dd><%= parsed.foodNecessity %></dd></div><% } %><div><dt>日付</dt><dd><%= parsed.transactionDate %></dd></div><div><dt>信頼度</dt><dd><%= ({high:'高',medium:'中',low:'低'})[parsed.confidence]||'低' %></dd></div></dl></div></div>
<div id="quick-actions" class="confirm-card <%= editMode?'hidden':'' %>"><form method="post" action="/transactions"><input type="hidden" name="amount" value="<%= parsed.amount %>"><input type="hidden" name="title" value="<%= parsed.title %>"><input type="hidden" name="merchant" value="<%= parsed.merchant||'' %>"><input type="hidden" name="category_id" value="<%= selectedId %>"><input type="hidden" name="auto_category_id" value="<%= selectedId %>"><input type="hidden" name="food_necessity" value="<%= parsed.foodNecessity||'未判定' %>"><input type="hidden" name="transaction_date" value="<%= parsed.transactionDate %>"><input type="hidden" name="type" value="<%= parsed.type %>"><input type="hidden" name="original_text" value="<%= parsed.originalText %>"><input type="hidden" name="classification_confidence" value="<%= parsed.confidence %>"><input type="hidden" name="memo" value="<%= parsed.memo %>"><button class="button primary wide" type="submit">この内容で登録</button></form><button id="show-edit" class="button ghost wide" type="button">内容を編集</button><a class="button ghost wide" href="/input">入力し直す</a></div>
<form id="parsed-edit" class="card form-grid parsed-edit <%= editMode?'':'hidden' %>" method="post" action="/transactions/register-edited">
  <input type="hidden" name="auto_category_id" value="<%= parsed.auto_category_id||selectedId %>"><input type="hidden" name="original_text" value="<%= parsed.originalText %>"><input type="hidden" name="classification_confidence" value="<%= parsed.confidence %>">
  <label>収支区分<select name="type" data-type-select><option value="expense" <%= parsed.type==='expense'?'selected':'' %>>支出</option><option value="income" <%= parsed.type==='income'?'selected':'' %>>収入</option></select></label>
  <label>金額<input name="amount" type="number" min="1" step="1" value="<%= parsed.amount %>" required></label>
  <label>内容<input name="title" value="<%= parsed.title %>" maxlength="160"></label><label>店名<input name="merchant" value="<%= parsed.merchant||'' %>" maxlength="120"></label>
  <label>カテゴリー<select name="category_id" data-category-select><% categories.forEach(c=>{ %><option value="<%= c.id %>" data-type="<%= c.type %>" <%= c.id===selectedId?'selected':'' %>><%= c.icon %> <%= c.name %></option><% }) %></select></label>
  <label>日付<input name="transaction_date" type="date" value="<%= parsed.transactionDate %>" required></label>
  <label data-food-field>食費の判定<select name="food_necessity"><% foodOptions.forEach(f=>{ %><option value="<%= f %>" <%= f===(parsed.foodNecessity||'未判定')?'selected':'' %>><%= f %></option><% }) %></select></label>
  <label class="full">メモ<textarea name="memo"><%= parsed.memo||'' %></textarea></label><button class="button primary full" type="submit">編集した内容で登録</button><a class="button ghost full" href="/input">入力し直す</a>
</form><% } %>
<form class="chat-form" method="post" action="/transactions/parse"><label class="sr-only" for="text">支出を自然文で入力</label><input id="text" name="text" required maxlength="500" autocomplete="off" placeholder="例：スタバ 550円" value="<%= parsed?'':text %>"><button type="submit" aria-label="解析する">➤</button></form>
</section><div class="examples"><span>試してみる</span><button data-example="昨日コンビニでお菓子300円">昨日コンビニでお菓子300円</button><button data-example="日吉から渋谷 電車 230円">日吉から渋谷 電車 230円</button><button data-example="給料 120000円">給料 120000円</button></div></div>
<%- include('partials/footer') %>
