<%- include('partials/header') %><div class="page-head"><div><p class="eyebrow">毎月の支払いを先に見える化</p><h1>固定費管理</h1></div></div><section class="two-col"><form class="card form-grid" method="post" action="/fixed-costs"><h2 class="full">固定費を追加</h2><label class="full">名前<input name="name" required maxlength="120" placeholder="例：家賃"></label><label>金額<input type="number" name="amount" min="1" required></label><label>引き落とし日<input type="number" name="billing_day" min="1" max="31" value="25" required></label><label>カテゴリー<select name="category"><option>固定費</option><option>交通費</option><option>趣味</option><option>生活費</option></select></label><label>開始月<input type="month" name="start_month" value="<%= new Date().toISOString().slice(0,7) %>" required></label><label>終了月（任意）<input type="month" name="end_month"></label><label class="full">メモ<textarea name="memo"></textarea></label><button class="button primary full">登録する</button></form><div><% if(!fixedCosts.length){ %><div class="card empty">固定費はまだありません。</div><% } fixedCosts.forEach(f=>{ %><details class="card fixed-item"><summary><div><b><%= f.name %></b><small>毎月<%= f.billing_day %>日 · <%= f.is_active?'有効':'停止中' %></small></div><strong>¥<%= f.amount.toLocaleString('ja-JP') %></strong></summary><form class="form-grid compact" method="post" action="/fixed-costs/<%= f.id %>/update"><label>名前<input name="name" value="<%= f.name %>" required></label><label>金額<input type="number" name="amount" min="1" value="<%= f.amount %>" required></label><label>引き落とし日<input type="number" name="billing_day" min="1" max="31" value="<%= f.billing_day %>" required></label><label>カテゴリー<select name="category"><% ['固定費','交通費','趣味','生活費'].forEach(c=>{ %><option <%= c===f.category?'selected':'' %>><%= c %></option><% }) %></select></label><label class="check"><input type="checkbox" name="is_active" <%= f.is_active?'checked':'' %>> 毎月繰り返す</label><label class="full">メモ<textarea name="memo"><%= f.memo||'' %></textarea></label><button class="button primary">更新</button></form><form method="post" action="/fixed-costs/<%= f.id %>/delete" data-confirm="この固定費を削除しますか？"><button class="text-danger">削除</button></form></details><% }) %></div></section><%- include('partials/footer') %>
