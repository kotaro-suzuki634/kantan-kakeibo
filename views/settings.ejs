<%- include('partials/header') %><div class="page-head"><div><p class="eyebrow">自分に合った目安に</p><h1>設定</h1></div></div><nav class="subnav"><a class="active" href="/settings">収入・予算</a><a href="/fixed-costs">固定費管理</a></nav><section class="two-col"><form class="card form-grid" method="post" action="/settings/income"><h2 class="full">月収と貯金</h2><label class="full">月収<input type="number" name="monthly_income" min="0" value="<%= user.monthly_income %>" required></label><label>給料日<input type="number" name="payday" min="1" max="31" value="<%= user.payday %>" required></label><label>毎月の貯金目標<input type="number" name="saving_target" min="0" value="<%= user.saving_target %>" required></label><button class="button primary full">収入設定を保存</button></form><form class="card form-grid" method="post" action="/settings/budgets"><h2 class="full">カテゴリーごとの目安割合</h2><p class="muted full">月収に対する割合です。合計は100%でなくても保存できます。</p><% budgets.forEach(b=>{ %><label><%= b.category %>（%）<input type="number" name="percentage_<%= b.category %>" min="0" max="100" step="0.1" value="<%= Number(b.percentage) %>" required></label><% }) %><button class="button primary full">予算設定を保存</button></form></section><%- include('partials/footer') %>
