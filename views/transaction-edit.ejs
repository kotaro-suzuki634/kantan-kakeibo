<%- include('partials/header') %><div class="narrow"><div class="page-head"><div><p class="eyebrow">分類が違うときだけ直せます</p><h1>記録を編集</h1></div></div><form class="card form-grid" method="post" action="/transactions/<%= transaction.id %>/update"><label>内容<input name="title" value="<%= transaction.title %>" required maxlength="160"></label><label>店名<input name="merchant" value="<%= transaction.merchant||'' %>" maxlength="120"></label><label>金額<input name="amount" type="number" min="1" step="1" value="<%= transaction.amount %>" required></label><label>日付<input name="transaction_date" type="date" value="<%= new Date(transaction.transaction_date).toISOString().slice(0,10) %>" required></label><label>カテゴリー<select name="category"><% categories.forEach(c=>{ %><option <%= c===transaction.category?'selected':'' %>><%= c %></option><% }) %></select></label><label>食費の判定<select name="food_necessity"><% foodOptions.forEach(f=>{ %><option <%= f===transaction.food_necessity?'selected':'' %>><%= f %></option><% }) %></select></label><label>支払い状態<select name="payment_status"><option value="paid" <%= transaction.payment_status==='paid'?'selected':'' %>>支払い済み</option><option value="scheduled" <%= transaction.payment_status==='scheduled'?'selected':'' %>>支出予定</option></select></label><label class="full">メモ<textarea name="memo"><%= transaction.memo||'' %></textarea></label><button class="button primary full" type="submit">変更を保存</button></form><form class="danger-zone" method="post" action="/transactions/<%= transaction.id %>/delete" data-confirm="この記録を削除しますか？"><button class="button danger" type="submit">この記録を削除</button></form></div><%- include('partials/footer') %>
