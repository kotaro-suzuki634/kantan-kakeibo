<%- include('partials/header') %><div class="narrow"><div class="page-head"><div><p class="eyebrow">分類が違うときだけ直せます</p><h1>記録を編集</h1></div></div><% if(errors?.length){ %><div class="form-errors"><ul><% errors.forEach(e=>{ %><li><%= e %></li><% }) %></ul></div><% } %><form class="card form-grid" method="post" action="/transactions/<%= transaction.id %>/update"><label>収支区分<select name="type" data-type-select><option value="expense" <%= transaction.type==='expense'?'selected':'' %>>支出</option><option value="income" <%= transaction.type==='income'?'selected':'' %>>収入</option></select></label><label>内容<input name="title" value="<%= transaction.title %>" maxlength="160"></label><label>店名<input name="merchant" value="<%= transaction.merchant||'' %>" maxlength="120"></label><label>金額<input name="amount" type="number" min="1" step="1" value="<%= transaction.amount %>" required></label><label>日付<input name="transaction_date" type="date" value="<%= String(transaction.transaction_date).slice(0,10) %>" required></label><label>カテゴリー<select name="category_id" data-category-select><% categories.forEach(c=>{ %><option value="<%= c.id %>" data-type="<%= c.type %>" <%= c.id===Number(transaction.category_id)||(!transaction.category_id&&c.name===transaction.category)?'selected':'' %>><%= c.icon %> <%= c.name %></option><% }) %></select></label><label data-food-field>食費の判定<select name="food_necessity"><% foodOptions.forEach(f=>{ %><option <%= f===(transaction.food_necessity||'未判定')?'selected':'' %>><%= f %></option><% }) %></select></label><label>支払い状態<select name="payment_status"><option value="paid" <%= transaction.payment_status==='paid'?'selected':'' %>>支払い済み</option><option value="scheduled" <%= transaction.payment_status==='scheduled'?'selected':'' %>>支出予定</option></select></label><label class="full">メモ<textarea name="memo"><%= transaction.memo||'' %></textarea></label><button class="button primary full" type="submit">変更を保存</button></form><form class="danger-zone" method="post" action="/transactions/<%= transaction.id %>/delete" data-confirm="この記録を削除しますか？"><button class="button danger" type="submit">この記録を削除</button></form></div><%- include('partials/footer') %>
