<%- include('partials/header') %><div class="page-head"><div><p class="eyebrow">自分らしい分類に</p><h1>カテゴリー設定</h1></div></div><nav class="subnav"><a href="/settings">収入・予算</a><a href="/fixed-costs">固定費管理</a><a class="active" href="/settings/categories">カテゴリー</a></nav>
<section class="two-col"><form class="card form-grid" method="post" action="/settings/categories"><h2 class="full">カテゴリーを追加</h2><label>名前<input name="name" maxlength="30" required placeholder="例：ペット"></label><label>収支区分<select name="type"><option value="expense">支出</option><option value="income">収入</option></select></label><label>色<input type="color" name="color" value="#718078"></label><label>アイコン（1〜2文字）<input name="icon" maxlength="10" value="●"></label><label>並び順<input type="number" name="sort_order" value="100"></label><label class="check"><input type="checkbox" name="include_in_budget" checked> 予算集計に含める</label><button class="button primary full">追加する</button></form><div class="card"><h2>使い方</h2><p class="muted">基本カテゴリーは削除できません。使わないカテゴリーは停止できます。記録に使われている追加カテゴリーを削除した場合も、履歴を守るため自動的に停止へ切り替わります。</p></div></section>
<section class="category-admin"><% categoryRows.forEach(c=>{ %><details class="card category-item"><summary><span class="category-swatch" style="background:<%= c.color %>"><%= c.icon %></span><div><b><%= c.name %></b><small><%= c.type==='income'?'収入':'支出' %> · <%= c.is_default?'基本':'追加' %> · <%= c.is_active?'使用中':'停止中' %><%= Number(c.transaction_count)?` · ${c.transaction_count}件`:'' %></small></div><span>編集</span></summary><form class="form-grid compact" method="post" action="/settings/categories/<%= c.id %>/update"><label>名前<input name="name" maxlength="30" value="<%= c.name %>" <%= c.is_default?'readonly':'' %> required></label><label>収支区分<select name="type" <%= c.is_default?'disabled':'' %>><option value="expense" <%= c.type==='expense'?'selected':'' %>>支出</option><option value="income" <%= c.type==='income'?'selected':'' %>>収入</option></select></label><label>色<input type="color" name="color" value="<%= c.color %>"></label><label>アイコン<input name="icon" maxlength="10" value="<%= c.icon %>"></label><label>並び順<input type="number" name="sort_order" value="<%= c.sort_order %>"></label><label class="check"><input type="checkbox" name="is_active" <%= c.is_active?'checked':'' %>> 使用する</label><label class="check"><input type="checkbox" name="include_in_budget" <%= c.include_in_budget?'checked':'' %> <%= c.type==='income'?'disabled':'' %>> 予算集計に含める</label><button class="button primary">更新</button></form><% if(!c.is_default){ %><form method="post" action="/settings/categories/<%= c.id %>/delete" data-confirm="このカテゴリーを削除しますか？ 使用中の場合は履歴を残して停止します。"><button class="text-danger">削除</button></form><% } %></details><% }) %></section><%- include('partials/footer') %>
