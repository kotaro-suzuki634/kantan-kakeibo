<%- include('partials/header') %><div class="page-head"><div><p class="eyebrow">1日ごとの使い方</p><h1>カレンダー</h1></div><a class="button primary" href="/input">＋ 入力</a></div><form class="month-form"><input type="month" name="month" value="<%= month %>"><button class="button ghost">表示</button></form><section class="calendar-card"><div class="week"><span>日</span><span>月</span><span>火</span><span>水</span><span>木</span><span>金</span><span>土</span></div><div id="calendar" class="calendar-grid" data-month="<%= month %>" data-transactions='<%- JSON.stringify(transactions).replace(/'/g,"&#39;") %>'></div></section><section id="day-detail" class="card"><div class="section-title"><h2>日付を選んでください</h2></div><p class="muted">その日の支出がここに表示されます。</p></section><div class="legend"><span class="food">食 食費</span><span class="transport">交 交通費</span><span class="life">生 生活費</span><span class="hobby">趣 趣味</span><span class="fixed">固 固定費</span></div><%- include('partials/footer') %>
